---
import "@/styles/global.css";
import Meta from "@/components/Meta.astro";
import { Font } from "astro:assets";

interface Props {
  title: string;
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" href="/icon.svg" type="image/svg+xml" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="This is my Portfolio to promote my working skills"
    />
    <meta name="author" content="Diego Páez" />
    <Font cssVariable="--font-fraunces" />
    <Font cssVariable="--font-inter" />
    <Font cssVariable="--font-geist" />

    <title>{Astro.props.title}</title>

    <Meta />
  </head>
  <body
    class="bg-background content-visibility w-dvw h-dvh flex flex-col gap-2 p-2 pb-4 overflow-x-hidden"
  >
    <slot />
  </body>
</html>
