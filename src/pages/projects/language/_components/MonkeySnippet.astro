<Snippet
  title="Monkey Program Example"
  lang="c"
  link="https://github.com/dyxgou/redis/blob/2d921761fc7db940e6bfdeb5695baf1b2b4f92be/pkg/serializer/serializer.go#L9"
  code={`let fibonacci = fn(x) {
  if (x == 0) {
    0
  } else {
    if (x == 1) {
      return 1;
    } else {
      fibonacci(x - 1) + fibonacci(x - 2);
    }
  }
};

print(fibonacci(10)) // 55`}
/>
